---
/**
 * Projects Component
 * Showcase of personal, academic, and professional projects
 */
import { portfolioData } from '../data/portfolio';

const { projects } = portfolioData;
---

<section id="projects" class="projects" data-reveal>
  <div class="section-container">
    <div class="section-header">
      <h2 class="section-title">My Projects</h2>
      <p class="section-subtitle">A collection of my work across different domains</p>
    </div>

    <div class="projects-grid stagger-children">
      {projects.map((project, index) => (
        <div class="project-card">
          <div class="project-watermark">{String(index + 1).padStart(2, '0')}</div>
          
          <div class="project-bar"></div>

          <div class="project-header">
            <h3 class="project-title">
              {project.url ? (
                <a href={project.url} target="_blank" rel="noopener noreferrer">
                  {project.title}
                  <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
                    <path d="M18 13v6a2 2 0 0 1-2 2H5a2 2 0 0 1-2-2V9a2 2 0 0 1 2-2h6"></path>
                    <polyline points="15 3 21 3 21 9"></polyline>
                    <line x1="10" y1="14" x2="21" y2="3"></line>
                  </svg>
                </a>
              ) : (
                project.title
              )}
            </h3>
          </div>

          <p class="project-description">{project.description}</p>

          <div class="project-tags">
            {project.technologies.map((tech) => (
              <span class="tech-tag">{tech}</span>
            ))}
          </div>

          {project.github && (
            <a href={project.github} target="_blank" rel="noopener noreferrer" class="project-link">
              View Project
              <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
                <path d="M5 12h14"></path>
                <path d="m12 5 7 7-7 7"></path>
              </svg>
            </a>
          )}
        </div>
      ))}
    </div>
  </div>
</section>

<style>
  .projects {
    padding: 5rem 2rem;
    background: linear-gradient(to bottom, rgba(0, 212, 255, 0.02), rgba(255, 0, 110, 0.02));
  }

  .section-container {
    max-width: 1200px;
    margin: 0 auto;
  }

  .section-header {
    margin-bottom: 3rem;
    text-align: center;
  }

  .section-title {
    font-size: 2.5rem;
    margin-bottom: 1rem;
    color: var(--text-primary);
  }

  .section-subtitle {
    font-size: 1.125rem;
    color: var(--text-muted);
  }

  .projects-grid {
    display: grid;
    grid-template-columns: repeat(auto-fill, minmax(320px, 1fr));
    gap: 2rem;
  }

  .project-card {
    background: var(--glass);
    border: 1px solid var(--border-color);
    border-radius: var(--radius-lg);
    padding: 2rem;
    position: relative;
    overflow: hidden;
    transition: all 0.3s ease;
    display: flex;
    flex-direction: column;
  }

  .project-watermark {
    position: absolute;
    top: -20px;
    right: -20px;
    font-size: 6rem;
    font-weight: 900;
    color: transparent;
    -webkit-background-clip: text;
    background-clip: text;
    background: linear-gradient(135deg, rgba(0, 212, 255, 0.1), rgba(255, 0, 110, 0.1));
    pointer-events: none;
    user-select: none;
  }

  .project-bar {
    position: absolute;
    top: 0;
    left: 0;
    right: 0;
    height: 3px;
    background: var(--gradient-primary);
    transform: scaleX(0);
    transform-origin: left;
    transition: transform 0.3s ease;
  }

  .project-card:hover .project-bar {
    transform: scaleX(1);
  }

  .project-card:hover {
    border-color: var(--primary-color);
    transform: translateY(-8px);
    background: rgba(15, 22, 40, 0.8);
    box-shadow: 0 20px 40px rgba(0, 212, 255, 0.1);
  }

  .project-header {
    margin-bottom: 1rem;
    position: relative;
    z-index: 1;
  }

  .project-title {
    font-size: 1.375rem;
    margin: 0;
    color: var(--text-primary);
  }

  .project-title a {
    display: inline-flex;
    align-items: center;
    gap: 0.5rem;
    color: inherit;
    transition: color 0.3s ease;
  }

  .project-title a:hover {
    color: var(--primary-color);
  }

  .project-description {
    color: var(--text-muted);
    font-size: 0.95rem;
    line-height: 1.6;
    margin-bottom: 1.5rem;
    flex-grow: 1;
    position: relative;
    z-index: 1;
  }

  .project-tags {
    display: flex;
    flex-wrap: wrap;
    gap: 0.5rem;
    margin-bottom: 1.5rem;
    position: relative;
    z-index: 1;
  }

  .tech-tag {
    display: inline-block;
    padding: 0.4rem 0.9rem;
    background: rgba(0, 212, 255, 0.12);
    border: 1px solid rgba(0, 212, 255, 0.3);
    border-radius: var(--radius-full);
    font-size: 0.75rem;
    color: var(--primary-color);
    font-weight: 500;
    transition: all 0.3s ease;
  }

  .project-card:hover .tech-tag {
    background: rgba(0, 212, 255, 0.18);
  }

  .project-link {
    display: inline-flex;
    align-items: center;
    gap: 0.5rem;
    padding: 0.75rem 1.5rem;
    background: linear-gradient(135deg, rgba(0, 212, 255, 0.15), rgba(255, 0, 110, 0.15));
    border: 1px solid var(--primary-color);
    border-radius: var(--radius-md);
    color: var(--primary-color);
    font-weight: 600;
    font-size: 0.95rem;
    transition: all 0.3s ease;
    width: fit-content;
    position: relative;
    z-index: 1;
  }

  .project-link:hover {
    background: linear-gradient(135deg, rgba(0, 212, 255, 0.25), rgba(255, 0, 110, 0.25));
    border-color: var(--primary-dark);
    transform: translateX(4px);
    box-shadow: 0 8px 16px rgba(0, 212, 255, 0.2);
  }

  /* Responsive */
  @media (max-width: 768px) {
    .projects {
      padding: 3rem 1.5rem;
    }

    .section-title {
      font-size: 1.875rem;
    }

    .projects-grid {
      grid-template-columns: 1fr;
      gap: 1.5rem;
    }

    .project-card {
      padding: 1.5rem;
    }

    .project-watermark {
      font-size: 4rem;
      top: -10px;
      right: -10px;
    }

    .project-title {
      font-size: 1.25rem;
    }
  }
</style>

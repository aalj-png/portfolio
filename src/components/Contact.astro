---
/**
 * Contact Component
 * Two-column layout with contact methods and contact form
 * Form integration with formsubmit.co for email
 */

import { portfolioData } from '../data/portfolio';
---

<section id="contact" class="relative py-20 md:py-32">
  <div class="container mx-auto px-6 md:px-12">
    <h2 class="text-4xl md:text-5xl font-bold mb-16">
      <span class="bg-gradient-to-r from-blue-400 to-cyan-400 bg-clip-text text-transparent">
        Let's Connect
      </span>
    </h2>

    <div class="grid md:grid-cols-2 gap-12">
      <!-- Contact Info -->
      <div class="space-y-8">
        {/* Contact Methods */}
        <div class="space-y-6">
          {/* Email */}
          <a
            href={`mailto:${portfolioData.personal.email}`}
            class="group flex items-start gap-4 p-6 rounded-xl glass hover:bg-color-primary/5 hover:border-color-primary/30 border border-transparent transition-all duration-300"
          >
            <div class="w-14 h-14 rounded-lg bg-gradient-to-br from-blue-500/20 to-cyan-500/20 flex items-center justify-center flex-shrink-0 group-hover:scale-110 group-hover:shadow-lg group-hover:shadow-blue-500/30 transition-all">
              <span class="text-2xl">✉️</span>
            </div>
            <div>
              <h3 class="font-semibold text-color-text">Email</h3>
              <p class="text-color-text-secondary text-sm">
                {portfolioData.personal.email}
              </p>
            </div>
          </a>

          {/* Location */}
          <div class="group flex items-start gap-4 p-6 rounded-xl glass hover:bg-color-primary/5 hover:border-color-primary/30 border border-transparent transition-all duration-300">
            <div class="w-14 h-14 rounded-lg bg-gradient-to-br from-purple-500/20 to-pink-500/20 flex items-center justify-center flex-shrink-0 group-hover:scale-110 group-hover:shadow-lg group-hover:shadow-purple-500/30 transition-all">
              <span class="text-2xl">📍</span>
            </div>
            <div>
              <h3 class="font-semibold text-color-text">Location</h3>
              <p class="text-color-text-secondary text-sm">
                {portfolioData.personal.location}
              </p>
            </div>
          </div>
        </div>

        <!-- Social Links -->
        <div class="space-y-4">
          <p class="text-sm uppercase tracking-widest text-color-text-muted">
            Follow Me
          </p>
          <div class="flex gap-3">
            {portfolioData.socialLinks.map((link) => (
              <a
                href={link.url}
                target={link.url.startsWith('mailto') ? '_self' : '_blank'}
                rel={link.url.startsWith('http') ? 'noopener noreferrer' : undefined}
                class="group w-12 h-12 rounded-lg glass flex items-center justify-center hover:bg-color-primary hover:text-color-bg hover:shadow-lg hover:shadow-blue-500/30 transition-all duration-300"
                aria-label={link.label}
              >
                <span class="text-xl">{link.name === 'Email' ? '✉' : link.name === 'GitHub' ? '🐙' : link.name === 'LinkedIn' ? 'in' : '🔗'}</span>
              </a>
            ))}
          </div>
        </div>
      </div>

      <!-- Contact Form -->
      <div>
        <form
          action="https://formsubmit.co/a.alj@esisa.ac.ma"
          method="POST"
          class="space-y-6"
        >
          {/* Name Input */}
          <div>
            <label for="name" class="block text-xs uppercase tracking-widest text-color-text-muted mb-2">
              Your Name
            </label>
            <input
              type="text"
              id="name"
              name="name"
              required
              class="w-full px-4 py-3 rounded-lg bg-color-bg-tertiary border-2 border-color-border focus:border-color-primary focus:outline-none transition-colors text-color-text placeholder-color-text-muted"
              placeholder="Ahmed Ratib"
            />
          </div>

          {/* Email Input */}
          <div>
            <label for="email" class="block text-xs uppercase tracking-widest text-color-text-muted mb-2">
              Your Email
            </label>
            <input
              type="email"
              id="email"
              name="email"
              required
              class="w-full px-4 py-3 rounded-lg bg-color-bg-tertiary border-2 border-color-border focus:border-color-primary focus:outline-none transition-colors text-color-text placeholder-color-text-muted"
              placeholder="you@example.com"
            />
          </div>

          {/* Subject Input */}
          <div>
            <label for="subject" class="block text-xs uppercase tracking-widest text-color-text-muted mb-2">
              Subject
            </label>
            <input
              type="text"
              id="subject"
              name="subject"
              required
              class="w-full px-4 py-3 rounded-lg bg-color-bg-tertiary border-2 border-color-border focus:border-color-primary focus:outline-none transition-colors text-color-text placeholder-color-text-muted"
              placeholder="Let's collaborate"
            />
          </div>

          {/* Message Input -->
          <div>
            <label for="message" class="block text-xs uppercase tracking-widest text-color-text-muted mb-2">
              Message
            </label>
            <textarea
              id="message"
              name="message"
              required
              rows={5}
              class="w-full px-4 py-3 rounded-lg bg-color-bg-tertiary border-2 border-color-border focus:border-color-primary focus:outline-none transition-colors text-color-text placeholder-color-text-muted resize-none"
              placeholder="Your message here..."
            ></textarea>
          </div>

          {/* Hidden field to avoid spam */}
          <input type="hidden" name="_captcha" value="false" />
          <input type="hidden" name="_next" value="https://portfolio-ahmed-alj.vercel.app/#contact" />

          {/* Submit Button */}
          <button
            type="submit"
            class="w-full py-3 px-6 rounded-lg bg-gradient-to-r from-blue-500 to-cyan-500 text-white font-bold hover:shadow-lg hover:shadow-blue-500/50 hover:scale-105 transition-all duration-300 flex items-center justify-center gap-2"
          >
            <span>Send Message</span>
            <span>→</span>
          </button>
        </form>
      </div>
    </div>
  </div>
</section>

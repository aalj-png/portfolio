---
/**
 * Footer Component
 * Three-column layout with branding, navigation, and social links
 */
import { portfolioData, getAvailableNavItems } from '../data/portfolio';

const navItems = getAvailableNavItems(portfolioData);
const { firstName, lastName } = portfolioData.personal;

const icons: Record<string, string> = {
  Github: '<path d="M9 19c-4.3 1.4-4.3-2.5-6-3m12 0c4.3 1.4 4.3-2.5 6-3M9 19c0 1.5.5 2 2 2s2-.5 2-2m-6-6v-6c0-1 .5-2 2-2h4c1.5 0 2 .5 2 2v4c0 1-.5 2-2 2h-4c-1.5 0-2-1-2-2zm4-2h2"></path>',
  Linkedin: '<path d="M16 8a6 6 0 0 1 6 6v7h-4v-7a2 2 0 0 0-2-2 2 2 0 0 0-2 2v7h-4v-7a6 6 0 0 1 6-6zM2 9h4v12H2z"></path><circle cx="4" cy="4" r="2"></circle>',
  Mail: '<rect x="2" y="4" width="20" height="16" rx="2"></rect><path d="m22 7-8.97 5.7a1.94 1.94 0 0 1-2.06 0L2 7"></path>',
};

function getIcon(iconName: string): string {
  return icons[iconName] || icons.Mail;
}
---

<footer class="footer">
  <div class="footer-container">
    <!-- Brand Section -->
    <div class="footer-section brand">
      <div class="footer-logo">
        <svg width="28" height="28" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
          <polyline points="12 3 20 7.5 20 16.5 12 21 4 16.5 4 7.5 12 3"></polyline>
        </svg>
        <span>{firstName} {lastName}</span>
      </div>
      <p class="footer-text">Computer Science Student & Web Developer. Building useful software and friendly web experiences.</p>
    </div>

    <!-- Navigation Section -->
    <div class="footer-section navigation">
      <h3>Navigation</h3>
      <ul class="footer-nav">
        {navItems.map((item) => (
          <li>
            <a href={item.href}>{item.label}</a>
          </li>
        ))}
      </ul>
    </div>

    <!-- Connect Section -->
    <div class="footer-section connect">
      <h3>Connect</h3>
      <div class="footer-social">
        {portfolioData.social.map((social) => (
          <a 
            href={social.url} 
            target="_blank" 
            rel="noopener noreferrer" 
            title={social.platform}
            class="social-link"
          >
            <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
              <path set:html={getIcon(social.icon)} />
            </svg>
            <span>{social.platform}</span>
          </a>
        ))}
      </div>
    </div>
  </div>

  <!-- Footer Bottom -->
  <div class="footer-bottom">
    <p>&copy; {new Date().getFullYear()} {firstName} {lastName}. All rights reserved.</p>
    <p class="footer-credit">Built with <a href="https://astro.build" target="_blank">Astro</a> and deployed on <a href="https://vercel.com" target="_blank">Vercel</a></p>
  </div>
</footer>

<style>
  .footer {
    background: var(--bg-secondary);
    border-top: 1px solid var(--border-color);
    margin-top: 6rem;
  }

  .footer-container {
    max-width: 1200px;
    margin: 0 auto;
    padding: 3rem 2rem;
    display: grid;
    grid-template-columns: repeat(auto-fit, minmax(250px, 1fr));
    gap: 3rem;
  }

  .footer-section h3 {
    font-size: 1.125rem;
    margin-bottom: 1.5rem;
    color: var(--text-primary);
  }

  .footer-logo {
    display: flex;
    align-items: center;
    gap: 0.75rem;
    font-weight: 700;
    color: var(--text-primary);
    margin-bottom: 1rem;
  }

  .footer-logo svg {
    color: var(--primary-color);
  }

  .footer-text {
    color: var(--text-muted);
    font-size: 0.95rem;
    line-height: 1.6;
  }

  .footer-nav {
    list-style: none;
    display: flex;
    flex-direction: column;
    gap: 0.75rem;
  }

  .footer-nav a {
    color: var(--text-muted);
    transition: color 0.3s ease, padding-left 0.3s ease;
    display: inline-block;
  }

  .footer-nav a:hover {
    color: var(--primary-color);
    padding-left: 0.5rem;
  }

  .footer-social {
    display: flex;
    flex-direction: column;
    gap: 0.75rem;
  }

  .social-link {
    display: flex;
    align-items: center;
    gap: 0.75rem;
    color: var(--text-muted);
    transition: all 0.3s ease;
    width: fit-content;
  }

  .social-link:hover {
    color: var(--primary-color);
    transform: translateX(4px);
  }

  .footer-bottom {
    border-top: 1px solid var(--border-color);
    padding: 2rem;
    text-align: center;
    color: var(--text-muted);
    font-size: 0.875rem;
  }

  .footer-bottom p {
    margin: 0.5rem 0;
  }

  .footer-credit a {
    color: var(--primary-color);
    transition: color 0.3s ease;
  }

  .footer-credit a:hover {
    color: var(--primary-dark);
  }

  @media (max-width: 768px) {
    .footer-container {
      padding: 2rem 1rem;
      gap: 2rem;
      grid-template-columns: 1fr;
    }

    .footer-bottom {
      padding: 1.5rem 1rem;
      font-size: 0.8rem;
    }
  }
</style>

---
/**
 * Footer Component
 * Three-column layout with branding, navigation, and social links
 * Copyright and credits
 */

import { portfolioData, navItems } from '../data/portfolio';
---

<footer class="relative border-t border-color-border mt-20 py-16">
  <div class="container mx-auto px-6 md:px-12">
    {/* Main Footer Content */}
    <div class="grid md:grid-cols-3 gap-12 mb-12">
      {/* Branding Column */}
      <div>
        <div class="flex items-center gap-2 mb-4">
          <div class="w-10 h-10 rounded-lg bg-gradient-to-br from-blue-500 to-cyan-500 flex items-center justify-center text-white font-bold">
            A
          </div>
          <span class="font-bold text-lg bg-gradient-to-r from-blue-400 to-cyan-400 bg-clip-text text-transparent">
            Ahmed Ratib
          </span>
        </div>
        <p class="text-color-text-secondary text-sm leading-relaxed max-w-xs">
          Computer Science Student. Building useful software and friendly web experiences.
        </p>
      </div>

      {/* Navigation Column */}
      <div>
        <h3 class="font-bold text-color-text mb-4">Quick Links</h3>
        <ul class="space-y-2">
          {navItems.map((item) => (
            <li>
              <a
                href={item.href}
                class="text-color-text-secondary hover:text-color-primary transition-colors text-sm"
              >
                {item.label}
              </a>
            </li>
          ))}
        </ul>
      </div>

      {/* Social Links Column */}
      <div>
        <h3 class="font-bold text-color-text mb-4">Connect</h3>
        <div class="flex flex-wrap gap-3">
          {portfolioData.socialLinks.map((link) => (
            <a
              href={link.url}
              target={link.url.startsWith('mailto') ? '_self' : '_blank'}
              rel={link.url.startsWith('http') ? 'noopener noreferrer' : undefined}
              class="w-10 h-10 rounded-lg glass flex items-center justify-center hover:bg-color-primary hover:text-color-bg hover:shadow-lg hover:shadow-blue-500/30 transition-all duration-300"
              aria-label={link.label}
            >
              <span class="text-sm font-bold">
                {link.name === 'Email'
                  ? '✉'
                  : link.name === 'GitHub'
                    ? 'GH'
                    : link.name === 'LinkedIn'
                      ? 'in'
                      : '↗'}
              </span>
            </a>
          ))}
        </div>
      </div>
    </div>

    {/* Divider */}
    <div class="h-px bg-gradient-to-r from-transparent via-color-border to-transparent mb-8"></div>

    {/* Bottom Footer */}
    <div class="flex flex-col md:flex-row items-center justify-between gap-4 text-sm text-color-text-muted">
      <p>&copy; 2026 Ahmed Ratib Alj. All rights reserved.</p>
      <div class="flex items-center gap-2">
        <span>Built with</span>
        <a href="https://astro.build" target="_blank" rel="noopener noreferrer" class="text-color-primary hover:underline">
          Astro
        </a>
        <span>&</span>
        <a href="https://vercel.com" target="_blank" rel="noopener noreferrer" class="text-color-primary hover:underline">
          Vercel
        </a>
      </div>
    </div>
  </div>
</footer>

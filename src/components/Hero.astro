---
/**
 * Hero Component
 * Full-height hero section with:
 * - Animated gradient text for name
 * - Profile photo with hue-rotate animation
 * - Availability badge with pulsing dot
 * - Action buttons
 * - Social links with icons
 * - Stats bar with gradient text
 * - Scroll indicator
 */

import { portfolioData } from '../data/portfolio';

const { personal, stats, socialLinks } = portfolioData;
---

<section
  id="home"
  class="relative min-h-screen pt-24 pb-16 flex items-center justify-center overflow-hidden"
>
  <!-- Scroll Background Effect -->
  <div class="fixed inset-0 -z-10 pointer-events-none" id="hero-bg"></div>

  <div class="container mx-auto px-6 md:px-12">
    <div class="grid md:grid-cols-2 gap-12 items-center">
      <!-- Left Content -->
      <div class="space-y-8 order-2 md:order-1">
        <!-- Name with gradient -->
        <div class="space-y-4">
          <h1
            class="text-5xl md:text-6xl lg:text-7xl font-bold leading-tight"
          >
            <span
              class="hero-title-gradient bg-gradient-to-r from-blue-400 via-cyan-400 to-blue-600 bg-clip-text text-transparent inline-block"
            >
              {personal.firstName}
            </span>
            <br />
            <span class="text-color-text">{personal.lastName}</span>
          </h1>
          <p class="text-xl md:text-2xl font-semibold text-color-primary">
            {personal.title}
          </p>
        </div>

        <!-- Subtitle and description -->
        <p class="text-lg text-color-text-secondary leading-relaxed max-w-lg">
          {personal.subtitle}
        </p>

        <!-- Availability badge -->
        <div class="flex items-center gap-3 w-fit">
          <div class="relative">
            <div
              class="absolute inset-0 bg-green-500 rounded-full animate-pulse"
            ></div>
            <div
              class="relative w-4 h-4 bg-green-400 rounded-full border-2 border-green-300"
            ></div>
          </div>
          <span class="text-sm font-medium text-color-text-secondary">
            {personal.availabilityStatus}
          </span>
        </div>

        <!-- Action buttons -->
        <div class="flex flex-wrap gap-4 pt-4">
          <a
            href="#projects"
            class="px-6 py-3 rounded-lg bg-gradient-to-r from-blue-500 to-cyan-500 text-white font-semibold hover:shadow-lg hover:shadow-blue-500/50 hover:translate-y-[-2px] transition-all duration-300"
          >
            View My Work
          </a>
          <a
            href="#contact"
            class="px-6 py-3 rounded-lg border-2 border-color-primary text-color-primary font-semibold hover:bg-color-primary/10 transition-all duration-300"
          >
            Get in Touch
          </a>
        </div>

        <!-- Social Links as pills -->
        <div class="flex flex-wrap gap-3 pt-4">
          {
            socialLinks.map((link) => (
              <a
                href={link.url}
                target={link.url.startsWith('mailto') ? '_self' : '_blank'}
                class="group px-4 py-2 rounded-full glass hover:bg-color-primary/20 hover:border-color-primary transition-all duration-300 flex items-center gap-2"
                rel={link.url.startsWith('http') ? 'noopener noreferrer' : undefined}
              >
                <span class="text-sm font-medium">{link.label}</span>
              </a>
            ))
          }
        </div>
      </div>

      <!-- Right - Profile Image -->
      <div class="order-1 md:order-2 flex justify-center md:justify-end">
        <div
          class="relative w-64 h-64 md:w-80 md:h-80"
        >
          <!-- Gradient Ring -->
          <div
            class="absolute inset-0 rounded-full bg-gradient-to-br from-blue-500 via-cyan-500 to-purple-500 animate-spin transform"
            style="animation: spin 8s linear infinite; --tw-animation-duration: 8s;"
          ></div>

          <!-- Image Container -->
          <div
            class="absolute inset-1 rounded-full bg-color-bg overflow-hidden"
          >
            <div
              class="w-full h-full bg-gradient-to-br from-blue-500/20 to-cyan-500/20 flex items-center justify-center group hover:scale-110 transition-transform duration-300"
            >
              <div class="text-center text-color-text-secondary">
                <div class="text-4xl">📸</div>
                <p class="text-sm mt-2">Profile Photo</p>
              </div>
            </div>
          </div>
        </div>
      </div>
    </div>

    <!-- Stats Bar -->
    <div class="mt-20 pt-16 border-t border-color-border">
      <div
        class="grid grid-cols-2 md:grid-cols-4 gap-8 md:gap-12"
      >
        {
          stats.map((stat) => (
            <div class="text-center">
              <div class="text-3xl md:text-4xl font-bold bg-gradient-to-r from-blue-400 to-cyan-400 bg-clip-text text-transparent">
                {stat.value}
              </div>
              <p class="text-sm text-color-text-muted mt-2">{stat.label}</p>
            </div>
          ))
        }
      </div>
    </div>

    <!-- Scroll Indicator -->
    <div class="absolute bottom-8 left-1/2 transform -translate-x-1/2 flex flex-col items-center gap-2">
      <p class="text-xs uppercase tracking-widest text-color-text-muted">Scroll to explore</p>
      <div
        class="w-6 h-10 border-2 border-color-text-muted rounded-full flex justify-center p-1 animate-bounce"
      >
        <div class="w-1 h-2 bg-color-text-muted rounded-full"></div>
      </div>
    </div>
  </div>
</section>

<style>
  @keyframes spin {
    from {
      transform: rotate(0deg);
    }
    to {
      transform: rotate(360deg);
    }
  }

  .hero-title-gradient {
    background-size: 200% 200%;
    animation: gradient-shift 8s ease infinite;
  }

  @keyframes gradient-shift {
    0% {
      background-position: 0% 50%;
    }
    50% {
      background-position: 100% 50%;
    }
    100% {
      background-position: 0% 50%;
    }
  }
</style>

<script>
  /**
   * Hero Background Parallax Effect
   * Creates a subtle parallax effect on scroll
   */

  const heroBg = document.getElementById('hero-bg');
  
  window.addEventListener('scroll', () => {
    if (heroBg) {
      const scrollY = window.pageYOffset;
      heroBg.style.transform = `translateY(${scrollY * 0.5}px)`;
    }
  });
</script>

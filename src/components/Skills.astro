---
/**
 * Skills Component
 * Technical Skills in grid with categories and icons
 * Soft Skills in horizontal layout with descriptions
 */

import { portfolioData } from '../data/portfolio';
---

<section
  id="skills"
  class="relative py-20 md:py-32 overflow-hidden"
>
  <div class="container mx-auto px-6 md:px-12">
    <h2 class="text-4xl md:text-5xl font-bold mb-16">
      <span class="bg-gradient-to-r from-blue-400 to-cyan-400 bg-clip-text text-transparent">
        Skills & Technologies
      </span>
    </h2>

    <!-- Technical Skills -->
    <div class="space-y-12">
      <div>
        <div class="flex items-center gap-4 mb-8">
          <h3 class="text-2xl font-bold text-color-text">Technical Skills</h3>
          <div class="flex-1 h-px bg-gradient-to-r from-blue-500/50 to-transparent"></div>
        </div>

        <div class="grid md:grid-cols-2 lg:grid-cols-3 gap-8">
          {
            portfolioData.technicalSkills.map((category, idx) => (
              <div
                class="group p-6 rounded-xl glass hover:bg-color-primary/5 hover:border-color-primary/30 border border-transparent transition-all duration-300 hover:translate-y-[-8px]"
                style={`animation: slideInUp 0.6s ease-out ${idx * 0.1}s backwards;`}
              >
                {/* Icon Container */}
                <div class="w-12 h-12 rounded-lg bg-gradient-to-br from-blue-500/20 to-cyan-500/20 flex items-center justify-center mb-4 group-hover:scale-110 group-hover:shadow-lg group-hover:shadow-blue-500/50 transition-all duration-300">
                  <span class="text-2xl">💻</span>
                </div>

                {/* Category Title */}
                <h4 class="text-lg font-bold text-color-text mb-4">
                  {category.category}
                </h4>

                {/* Skills Chips */}
                <div class="flex flex-wrap gap-2 mb-4">
                  {category.skills.map((skill) => (
                    <span class="px-3 py-1 rounded-full bg-color-primary/20 text-color-primary text-xs font-medium border border-color-primary/30 hover:bg-color-primary/30 transition-colors">
                      {skill.name}
                    </span>
                  ))}
                </div>

                {/* Skill Count */}
                <p class="text-xs text-color-text-muted font-mono">
                  {category.skills.length} skills
                </p>
              </div>
            ))
          }
        </div>
      </div>

      <!-- Soft Skills -->
      {
        portfolioData.softSkills && portfolioData.softSkills.length > 0 && (
          <div>
            <div class="flex items-center gap-4 mb-8">
              <h3 class="text-2xl font-bold text-color-text">Soft Skills</h3>
              <div class="flex-1 h-px bg-gradient-to-r from-purple-500/50 to-transparent"></div>
            </div>

            <div class="grid md:grid-cols-2 gap-6">
              {portfolioData.softSkills.map((skill, idx) => (
                <div
                  class="p-6 rounded-xl glass hover:bg-color-accent-secondary/5 hover:border-color-accent-secondary/30 border border-transparent transition-all duration-300 hover:translate-y-[-4px]"
                  style={`animation: slideInUp 0.6s ease-out ${idx * 0.1}s backwards;`}
                >
                  <div class="flex items-start gap-4">
                    {/* Icon */}
                    <div class="w-12 h-12 rounded-lg bg-gradient-to-br from-purple-500/20 to-pink-500/20 flex items-center justify-center flex-shrink-0 group hover:scale-110 transition-transform">
                      <span class="text-xl">✨</span>
                    </div>

                    {/* Content */}
                    <div>
                      <h4 class="text-lg font-bold text-color-text">
                        {skill.name}
                      </h4>
                      <p class="text-sm text-color-text-secondary mt-1">
                        {skill.description}
                      </p>
                    </div>
                  </div>
                </div>
              ))}
            </div>
          </div>
        )
      }
    </div>
  </div>
</section>

<style>
  @keyframes slideInUp {
    from {
      opacity: 0;
      transform: translateY(20px);
    }
    to {
      opacity: 1;
      transform: translateY(0);
    }
  }
</style>

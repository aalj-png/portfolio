---
/**
 * Header Component
 * Sticky navigation with glassmorphism effect
 * Mobile menu with hamburger animation
 * Auto-highlighting of active sections via IntersectionObserver
 */

import { navItems } from '../data/portfolio';
---

<header
  id="header"
  class="fixed top-0 left-0 right-0 z-40 glass border-b border-color-border h-16"
>
  <nav class="h-full px-6 md:px-12 flex items-center justify-between">
    <!-- Logo -->
    <a href="#home" class="flex items-center gap-2 group">
      <div
        class="w-10 h-10 rounded-lg bg-gradient-to-br from-blue-500 to-cyan-500 flex items-center justify-center text-white font-bold group-hover:scale-110 transition-transform"
      >
        A
      </div>
      <span class="hidden sm:inline font-bold text-lg bg-gradient-to-r from-blue-400 to-cyan-400 bg-clip-text text-transparent">
        Ahmed Ratib
      </span>
    </a>

    <!-- Desktop Navigation -->
    <div class="hidden md:flex items-center gap-1">
      {
        navItems.map((item) => (
          <a
            href={item.href}
            class="nav-link px-4 py-2 rounded-lg text-sm font-medium text-color-text-secondary hover:text-color-primary transition-colors relative group whitespace-nowrap"
            data-nav-href={item.href}
          >
            {item.label}
            <span class="absolute bottom-1 left-4 right-4 h-0.5 bg-gradient-to-r from-blue-500 to-cyan-500 scale-x-0 group-hover:scale-x-100 transition-transform origin-left"></span>
          </a>
        ))
      }
    </div>

    <!-- Mobile Menu Button -->
    <button
      id="menu-toggle"
      class="md:hidden flex flex-col justify-center items-center w-8 h-8 relative"
      aria-label="Toggle menu"
      aria-expanded="false"
    >
      <span class="hamburger-line"></span>
      <span class="hamburger-line"></span>
      <span class="hamburger-line"></span>
    </button>
  </nav>

  <!-- Mobile Menu Drawer -->
  <div
    id="mobile-menu"
    class="hidden md:hidden fixed inset-0 top-16 bg-color-bg/95 backdrop-blur-md z-30 flex flex-col overflow-y-auto"
  >
    <div class="p-6 space-y-2">
      {
        navItems.map((item) => (
          <a
            href={item.href}
            class="block px-4 py-3 rounded-lg text-lg font-medium text-color-text hover:bg-color-bg-tertiary hover:text-color-primary transition-colors nav-link-mobile"
            data-nav-href={item.href}
          >
            {item.label}
          </a>
        ))
      }
    </div>

    <!-- Social Links in Mobile Menu -->
    <div class="mt-auto p-6 border-t border-color-border">
      <p class="text-xs uppercase tracking-widest text-color-text-muted mb-4">Connect</p>
      <div class="flex gap-3">
        <a
          href="mailto:a.alj@esisa.ac.ma"
          class="w-10 h-10 rounded-lg glass flex items-center justify-center hover:bg-color-primary hover:text-color-bg transition-colors"
          aria-label="Email"
        >
          ✉
        </a>
        <a
          href="https://github.com/aalj-png"
          target="_blank"
          class="w-10 h-10 rounded-lg glass flex items-center justify-center hover:bg-color-primary hover:text-color-bg transition-colors"
          aria-label="GitHub"
        >
          G
        </a>
        <a
          href="https://ma.linkedin.com/in/ahmed-ratib-alj-b39549391"
          target="_blank"
          class="w-10 h-10 rounded-lg glass flex items-center justify-center hover:bg-color-primary hover:text-color-bg transition-colors"
          aria-label="LinkedIn"
        >
          in
        </a>
      </div>
    </div>
  </div>
</header>

<style>
  .hamburger-line {
    @apply w-6 h-0.5 bg-color-text rounded-full transition-all duration-300 block;
  }

  #menu-toggle.active .hamburger-line:nth-child(1) {
    @apply translate-y-2.5 rotate-45;
  }

  #menu-toggle.active .hamburger-line:nth-child(2) {
    @apply opacity-0;
  }

  #menu-toggle.active .hamburger-line:nth-child(3) {
    @apply -translate-y-2.5 -rotate-45;
  }
</style>

<script>
  /**
   * Mobile Menu Functionality
   * - Toggle menu on button click
   * - Close on backdrop click
   * - Close on escape key
   * - Close on link click
   */

  const menuToggle = document.getElementById('menu-toggle');
  const mobileMenu = document.getElementById('mobile-menu');
  const navLinksMobile = document.querySelectorAll('.nav-link-mobile');

  function toggleMenu() {
    const isOpen = mobileMenu?.classList.contains('hidden') === false;
    if (isOpen) {
      mobileMenu?.classList.add('hidden');
      menuToggle?.classList.remove('active');
      document.body.style.overflow = '';
    } else {
      mobileMenu?.classList.remove('hidden');
      menuToggle?.classList.add('active');
      document.body.style.overflow = 'hidden';
    }
  }

  menuToggle?.addEventListener('click', toggleMenu);

  // Close menu on link click
  navLinksMobile.forEach((link) => {
    link.addEventListener('click', () => {
      setTimeout(toggleMenu, 100);
    });
  });

  // Close menu on escape key
  document.addEventListener('keydown', (e) => {
    if (e.key === 'Escape' && mobileMenu?.classList.contains('hidden') === false) {
      toggleMenu();
    }
  });

  // Close menu on backdrop click (outside menu)
  mobileMenu?.addEventListener('click', (e) => {
    if (e.target === mobileMenu) {
      toggleMenu();
    }
  });

  /**
   * Active Link Highlighting via IntersectionObserver
   * Automatically highlights the nav link for the current section
   */

  const observer = new IntersectionObserver(
    (entries) => {
      const activeEntry = entries.find((entry) => entry.isIntersecting);

      if (activeEntry) {
        const targetId = activeEntry.target.id;
        const navLinks = document.querySelectorAll(
          '.nav-link-mobile, .nav-link'
        );

        navLinks.forEach((link) => {
          const href = link.getAttribute('data-nav-href');
          if (href === `#${targetId}`) {
            link.classList.add('!text-color-primary', 'font-semibold');
          } else {
            link.classList.remove('!text-color-primary', 'font-semibold');
          }
        });
      }
    },
    {
      threshold: 0.3,
      rootMargin: '-50% 0px -50% 0px',
    }
  );

  // Observe all sections
  document.querySelectorAll('section[id]').forEach((section) => {
    observer.observe(section);
  });
</script>

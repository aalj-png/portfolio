---
/**
 * About Component
 * Two-column layout with numbered cards
 * Gradient accent bar on left with hover effects
 */

import { portfolioData } from '../data/portfolio';

const aboutContent = [
  {
    number: '01',
    title: 'My Journey',
    description: portfolioData.personal.description,
  },
  {
    number: '02',
    title: 'Current Focus',
    description:
      'Building a strong foundation in computer science fundamentals while applying knowledge to real-world projects. Passionate about web development and creating user-focused solutions.',
  },
  {
    number: '03',
    title: 'What Drives Me',
    description:
      'I thrive on solving challenging problems and learning new technologies. I am actively seeking internships and collaborations to apply my skills to meaningful projects that make a difference.',
  },
  {
    number: '04',
    title: 'Beyond Code',
    description:
      'Active in charity initiatives and sports club at ESISA. These experiences have taught me the value of teamwork, communication, and project organization.',
  },
];
---

<section id="about" class="relative py-20 md:py-32 overflow-hidden">
  <div class="container mx-auto px-6 md:px-12">
    <h2 class="text-4xl md:text-5xl font-bold mb-16">
      <span class="bg-gradient-to-r from-blue-400 to-cyan-400 bg-clip-text text-transparent">
        About Me
      </span>
    </h2>

    <div class="grid md:grid-cols-2 gap-8 md:gap-12">
      {
        aboutContent.map((card, index) => (
          <div
            class="group relative p-8 rounded-xl glass hover:bg-color-primary/5 transition-all duration-300 hover:translate-y-[-8px] border border-transparent hover:border-color-primary/30"
            style={`animation: fadeIn 0.6s ease-out ${index * 0.1}s backwards;`}
          >
            {/* Left Accent Bar */}
            <div class="absolute left-0 top-0 bottom-0 w-1 bg-gradient-to-b from-blue-500 to-cyan-500 rounded-l-xl"></div>

            {/* Number Badge */}
            <div class="text-7xl font-mono font-bold text-color-text-muted/20 mb-4">
              {card.number}
            </div>

            {/* Content */}
            <h3 class="text-2xl font-bold text-color-text mb-4">{card.title}</h3>
            <p class="text-color-text-secondary leading-relaxed">
              {card.description}
            </p>

            {/* Top Gradient Line on Hover */}
            <div
              class="absolute top-0 left-0 right-0 h-0.5 bg-gradient-to-r from-blue-500 to-cyan-500 scale-x-0 group-hover:scale-x-100 transition-transform origin-left"
            ></div>
          </div>
        ))
      }
    </div>
  </div>
</section>

<style>
  @keyframes fadeIn {
    from {
      opacity: 0;
      transform: translateY(20px);
    }
    to {
      opacity: 1;
      transform: translateY(0);
    }
  }
</style>

<script>
  /**
   * Scroll Reveal Animation
   * Elements fade in and slide up as they come into view
   */

  const observerConfig = {
    threshold: 0,
    rootMargin: '0px 0px -100px 0px',
  };

  const observer = new IntersectionObserver((entries) => {
    entries.forEach((entry) => {
      if (entry.isIntersecting) {
        entry.target.classList.add('animate-in');
        observer.unobserve(entry.target);
      }
    });
  }, observerConfig);

  document.querySelectorAll('#about > div > div > div[class*="group"]').forEach((el) => {
    observer.observe(el);
  });
</script>

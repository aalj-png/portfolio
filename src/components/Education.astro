---
/**
 * Education Component
 * Vertical timeline with education entries
 */
import { portfolioData } from '../data/portfolio';

const { education } = portfolioData;
---

<section id="education" class="education" data-reveal>
  <div class="section-container">
    <div class="section-header">
      <h2 class="section-title">Education</h2>
      <p class="section-subtitle">My academic journey and qualifications</p>
    </div>

    <div class="timeline">
      {education.map((edu, index) => (
        <div class="timeline-item" key={index}>
          {index === 0 && <div class="timeline-badge latest">Latest</div>}
          
          <div class="timeline-marker">
            <div class="timeline-dot">
              <div class="timeline-pulse"></div>
            </div>
          </div>

          <div class="timeline-content">
            <div class="edu-header">
              <div class="edu-period">{edu.startYear} {edu.endYear ? `- ${edu.endYear}` : '- Present'}</div>
              <h3 class="edu-degree">{edu.degree}</h3>
              <p class="edu-field">{edu.field}</p>
            </div>

            <div class="edu-institution">
              {edu.institutionUrl ? (
                <a href={edu.institutionUrl} target="_blank" rel="noopener noreferrer">
                  {edu.institution}
                  <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
                    <path d="M18 13v6a2 2 0 0 1-2 2H5a2 2 0 0 1-2-2V9a2 2 0 0 1 2-2h6"></path>
                    <polyline points="15 3 21 3 21 9"></polyline>
                    <line x1="10" y1="14" x2="21" y2="3"></line>
                  </svg>
                </a>
              ) : (
                <span>{edu.institution}</span>
              )}
            </div>

            {edu.description && <p class="edu-description">{edu.description}</p>}
          </div>
        </div>
      ))}
    </div>
  </div>
</section>

<style>
  .education {
    padding: 5rem 2rem;
    background: linear-gradient(to bottom, rgba(0, 212, 255, 0.03), transparent);
  }

  .section-container {
    max-width: 900px;
    margin: 0 auto;
  }

  .section-header {
    margin-bottom: 3rem;
    text-align: center;
  }

  .section-title {
    font-size: 2.5rem;
    margin-bottom: 1rem;
    color: var(--text-primary);
  }

  .section-subtitle {
    font-size: 1.125rem;
    color: var(--text-muted);
  }

  .timeline {
    position: relative;
  }

  .timeline::before {
    content: '';
    position: absolute;
    left: 50%;
    transform: translateX(-50%);
    top: 0;
    bottom: 0;
    width: 2px;
    background: linear-gradient(to bottom, var(--primary-color), var(--accent-color), transparent);
  }

  .timeline-item {
    display: grid;
    grid-template-columns: 1fr auto 1fr;
    gap: 2rem;
    margin-bottom: 2rem;
    position: relative;
  }

  .timeline-item:nth-child(odd) .timeline-content {
    grid-column: 1;
    text-align: right;
  }

  .timeline-item:nth-child(even) .timeline-content {
    grid-column: 3;
    text-align: left;
  }

  .timeline-badge {
    position: absolute;
    top: 0;
    left: 50%;
    transform: translateX(-50%);
    font-size: 0.75rem;
    font-weight: 700;
    text-transform: uppercase;
    letter-spacing: 0.1em;
    background: var(--gradient-success);
    color: var(--bg-primary);
    padding: 0.4rem 0.8rem;
    border-radius: var(--radius-full);
    z-index: 10;
  }

  .timeline-marker {
    display: flex;
    justify-content: center;
    align-items: center;
    grid-column: 2;
  }

  .timeline-dot {
    width: 20px;
    height: 20px;
    background: linear-gradient(135deg, var(--primary-color), var(--accent-color));
    border-radius: 50%;
    position: relative;
    box-shadow: 0 0 0 4px var(--bg-primary);
    animation: dotGlow 2s ease-in-out infinite;
  }

  .timeline-pulse {
    position: absolute;
    inset: -6px;
    border: 2px solid var(--primary-color);
    border-radius: 50%;
    animation: pulse 2s ease-in-out infinite;
    opacity: 0.5;
  }

  @keyframes dotGlow {
    0%, 100% {
      box-shadow: 0 0 0 4px var(--bg-primary), 0 0 12px rgba(0, 212, 255, 0.3);
    }
    50% {
      box-shadow: 0 0 0 4px var(--bg-primary), 0 0 20px rgba(0, 212, 255, 0.5);
    }
  }

  @keyframes pulse {
    0%, 100% {
      transform: scale(1);
      opacity: 0.5;
    }
    50% {
      transform: scale(1.2);
      opacity: 0;
    }
  }

  .timeline-content {
    background: var(--glass);
    padding: 2rem;
    border-radius: var(--radius-lg);
    border: 1px solid var(--border-color);
    transition: all 0.3s ease;
  }

  .timeline-content:hover {
    border-color: var(--primary-color);
    background: rgba(15, 22, 40, 0.7);
    transform: translateY(-4px);
  }

  .edu-header {
    margin-bottom: 1rem;
  }

  .edu-period {
    display: inline-block;
    font-family: var(--font-mono);
    font-size: 0.8rem;
    background: rgba(0, 212, 255, 0.1);
    border: 1px solid rgba(0, 212, 255, 0.3);
    padding: 0.4rem 0.8rem;
    border-radius: var(--radius-full);
    color: var(--primary-color);
    margin-bottom: 1rem;
  }

  .edu-degree {
    font-size: 1.5rem;
    color: var(--text-primary);
    margin-bottom: 0.25rem;
  }

  .edu-field {
    color: var(--primary-color);
    font-weight: 600;
    font-size: 1rem;
  }

  .edu-institution {
    margin: 1rem 0;
  }

  .edu-institution a,
  .edu-institution span {
    display: inline-flex;
    align-items: center;
    gap: 0.5rem;
    color: var(--text-muted);
    transition: color 0.3s ease;
    font-weight: 500;
  }

  .edu-institution a:hover {
    color: var(--primary-color);
  }

  .edu-description {
    color: var(--text-muted);
    font-size: 0.95rem;
    line-height: 1.6;
    margin-top: 0.75rem;
  }

  /* Mobile/Tablet */
  @media (max-width: 768px) {
    .education {
      padding: 3rem 1.5rem;
    }

    .section-title {
      font-size: 1.875rem;
    }

    .timeline::before {
      left: 20px;
      transform: translateX(-50%);
    }

    .timeline-item {
      grid-template-columns: auto 1fr;
      gap: 1.5rem;
    }

    .timeline-item:nth-child(odd) .timeline-content,
    .timeline-item:nth-child(even) .timeline-content {
      grid-column: 2;
      text-align: left;
    }

    .timeline-marker {
      grid-column: 1;
    }

    .timeline-dot {
      width: 16px;
      height: 16px;
    }

    .timeline-content {
      padding: 1.5rem;
    }

    .edu-degree {
      font-size: 1.25rem;
    }
  }
</style>

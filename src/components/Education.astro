---
/**
 * Education Component
 * Vertical timeline with gradient dots and connecting line
 * Badge for current/latest education
 */

import { portfolioData } from '../data/portfolio';
---

{
  portfolioData.education.length > 0 && (
    <section id="education" class="relative py-20 md:py-32">
      <div class="container mx-auto px-6 md:px-12">
        <h2 class="text-4xl md:text-5xl font-bold mb-16">
          <span class="bg-gradient-to-r from-blue-400 to-cyan-400 bg-clip-text text-transparent">
            Education
          </span>
        </h2>

        {/* Timeline Container */}
        <div class="relative pl-8 md:pl-12">
          {/* Timeline Line */}
          <div class="hidden md:block absolute left-5 top-0 bottom-0 w-0.5 bg-gradient-to-b from-blue-500 to-cyan-500"></div>

          {/* Timeline Items */}
          <div class="space-y-12">
            {portfolioData.education.map((edu, index) => (
              <div
                class="relative group animate-fade-in"
                style={`animation-delay: ${index * 0.2}s;`}
              >
                {/* Timeline Dot */}
                <div class="absolute -left-9 md:-left-12 top-8 w-8 md:w-10 h-8 md:h-10 rounded-full bg-gradient-to-br from-blue-500 to-cyan-500 flex items-center justify-center border-4 border-color-bg shadow-lg shadow-blue-500/50 animate-glow">
                  <div class="w-3 md:w-4 h-3 md:h-4 bg-color-bg rounded-full"></div>
                </div>

                {/* Education Card */}
                <div class="p-6 md:p-8 rounded-xl glass border border-transparent hover:border-color-primary/30 hover:bg-color-primary/5 transition-all duration-300">
                  {/* Header with Badge */}
                  <div class="flex flex-wrap items-start gap-4 mb-4">
                    <div class="flex-1">
                      <h3 class="text-2xl font-bold text-color-text">
                        {edu.degree}
                      </h3>
                      <p class="text-color-primary font-semibold">
                        {edu.field}
                      </p>
                    </div>

                    {/* Latest Badge */}
                    {edu.current && (
                      <span class="px-3 py-1 rounded-full bg-green-500/20 text-green-400 text-xs font-semibold border border-green-500/30 whitespace-nowrap">
                        Current
                      </span>
                    )}

                    {/* Year Badge */}
                    <span class="px-4 py-1 rounded-lg bg-color-bg-tertiary font-mono text-sm text-color-text-muted">
                      {edu.startYear}
                      {edu.endYear && ` - ${edu.endYear}`}
                      {edu.current && ' - Present'}
                    </span>
                  </div>

                  {/* Institution Link */}
                  <a
                    href={edu.url || '#'}
                    target={edu.url ? '_blank' : undefined}
                    class="inline-flex items-center gap-2 text-color-accent hover:text-color-accent-secondary transition-colors mb-4 font-medium"
                  >
                    {edu.institution}
                    {edu.url && <span>↗</span>}
                  </a>

                  {/* Description */}
                  {edu.description && (
                    <p class="text-color-text-secondary leading-relaxed">
                      {edu.description}
                    </p>
                  )}
                </div>
              </div>
            ))}
          </div>
        </div>
      </div>
    </section>
  )
}

<style>
  @keyframes glow {
    0%, 100% {
      box-shadow: 0 0 10px rgba(59, 130, 246, 0.5);
    }
    50% {
      box-shadow: 0 0 20px rgba(59, 130, 246, 0.8);
    }
  }

  .animate-glow {
    animation: glow 2s ease-in-out infinite;
  }

  @keyframes fade-in {
    from {
      opacity: 0;
      transform: translateY(20px);
    }
    to {
      opacity: 1;
      transform: translateY(0);
    }
  }

  .animate-fade-in {
    animation: fade-in 0.6s ease-out forwards;
  }
</style>
